# .env.example — Variáveis de ambiente necessárias
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o .env.local com valores reais

# Upstash Redis (Vercel KV) — armazenamento do blog
KV_REST_API_URL=https://seu-endpoint.upstash.io
KV_REST_API_TOKEN=seu-token-aqui

# Google Analytics 4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend — envio de newsletter
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=newsletter@seudominio.com.br

# URL do site (para links de cancelamento de inscrição nos emails)
NEXT_PUBLIC_SITE_URL=https://mbfinance.com.br

# Token admin do blog
BLOG_ADMIN_TOKEN=mbfinance2026

# (opcional) Google Sheets — URL do Apps Script para captura de leads
# Configurada diretamente no public/assets/js/infra/sheets.js com ofuscação atob()
