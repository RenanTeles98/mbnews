{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)",
      "Bash(git rm *)",
      "Bash(git commit *)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || (git commit -m \"auto: atualização MB News\" && git push origin main)",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Publicando no GitHub e Vercel..."
          }
        ]
      }
    ]
  }
}
